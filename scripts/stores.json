      "allowed_hosts": [
        "pichau.com.br",
        "www.pichau.com.br"
      ],
      "product_url_patterns": [
        "^/(?!search(?:/|$)|hardware(?:/|$)|marca(?:/|$)|fabricante(?:/|$)|categoria(?:/|$))[^?#]+-[^?#]+$"
      ],
      "link_selectors": [
        "main a[href]",
