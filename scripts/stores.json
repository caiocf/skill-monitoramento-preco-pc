{
  "stores": [
    {
      "name": "KaBuM",
      "enabled": true,
      "base_url": "https://www.kabum.com.br",
      "search_url": "https://www.kabum.com.br/busca/{query_slug}",
      "allowed_hosts": [
        "kabum.com.br",
        "www.kabum.com.br"
      ],
      "product_url_patterns": [
        "/produto/\\d+/"
      ],
      "link_selectors": [
        "a[href*='/produto/']"
      ],
      "wait_ms": 2500,
      "max_candidates": 4
    },
    {
      "name": "Pichau",
      "enabled": true,
      "base_url": "https://www.pichau.com.br",
